{
  "version": 2,
  "builds": [
    {
      "src": "dist/src/main.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/src/main.js"
    }
  ],
  "env": {
    "DATABASE_URL": "file:./vercel.db",
    "JWT_SECRET": "specflow-super-secret-jwt-key-2025",
    "JWT_EXPIRES_IN": "7d",
    "NODE_ENV": "production",
    "FRONTEND_URL": "https://your-frontend-project.vercel.app",
    "BACKEND_PUBLIC_URL": "https://your-backend-project.vercel.app",
    "PUBLIC_API_URL": "https://your-backend-project.vercel.app/api",
    "CORS_ORIGIN": "https://your-frontend-project.vercel.app"
  }
}
