# Database
# Runtime prefere DIRECT_URL porque o pooler da porta 6543 estava falhando no backend hospedado.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

# Supabase
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="[YOUR-SUPABASE-ANON-KEY]"
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SUPABASE-SERVICE-ROLE-KEY]"

# JWT
JWT_SECRET="[YOUR-JWT-SECRET]"
JWT_ALGORITHM="HS256"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
FRONTEND_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:3000,https://thamirescandidabarbosa.github.io"

# Google OAuth
GOOGLE_CLIENT_ID="[YOUR-GOOGLE-CLIENT-ID]"
GOOGLE_CLIENT_SECRET="[YOUR-GOOGLE-CLIENT-SECRET]"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/auth/google/callback"

# Environment
NODE_ENV="development"
