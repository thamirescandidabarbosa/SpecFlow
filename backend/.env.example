# Database
# Use qualquer Postgres compativel com Prisma, como Postgres local, Render, Neon ou Supabase.
DATABASE_URL="postgresql://admin:password@localhost:5432/fullstack_db"
DIRECT_URL="postgresql://admin:password@localhost:5432/fullstack_db"


# JWT
JWT_SECRET="[YOUR-JWT-SECRET]"
JWT_ALGORITHM="HS256"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
FRONTEND_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:3000,https://thamirescandidabarbosa.github.io"
BACKEND_PUBLIC_URL="http://localhost:3001"
PUBLIC_API_URL="http://localhost:3001/api"

# Google OAuth
GOOGLE_CLIENT_ID="[YOUR-GOOGLE-CLIENT-ID]"
GOOGLE_CLIENT_SECRET="[YOUR-GOOGLE-CLIENT-SECRET]"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/auth/google/callback"

# Supabase (opcional)
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_ANON_KEY=""

# Environment
NODE_ENV="development"
